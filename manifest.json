{
  "manifest_version": 2,
  "name": "FX OSK improved",
  "version": "1.0.0",
  "description": "Improved version of the On-Screen Keyboard for FireFox",
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "content_scripts": [
    {
      "all_frames": true,
      "matches": ["<all_urls>"],
      "js": ["keyboard.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "webRequest",
    "tabs",
    "storage",
    "activeTab",
    "<all_urls>",
    "webNavigation"
  ],

  "options_ui": {
    "page": "options/osk_settings.html",
    "browser_style": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "l.schwarz@ds-automotion.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
